# Provider order: auto prefers DeepSeek, then OpenAI, then the local deterministic fallback.
AI_PROVIDER=auto

# Server-side only. Never expose real keys to browser code or commit them.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
# Optional for compatible gateways or local integration tests.
# DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
